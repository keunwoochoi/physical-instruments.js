{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://instruments.js/evals/listening/analysis-manifest-schema-v1.json",
  "title": "instruments.js sealed blind-listening analysis key v1",
  "type": "object",
  "required": ["schema_version", "experiment", "experiment_digest", "provenance", "trials"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "experiment": { "type": "string", "pattern": "^(?!/)(?!.*\\.\\.).+\\.json$" },
    "experiment_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "provenance": {
      "type": "object",
      "required": ["generator", "candidate_commit", "baseline_commit", "metric_version", "case_manifest_sha256"],
      "properties": {
        "generator": { "enum": ["campaign-ab-v1", "campaign-ab-v2"] },
        "candidate_commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "baseline_commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "metric_version": { "type": "string", "minLength": 1 },
        "case_manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "case_schema_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "reference_registry_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "reference_registry_schema_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "blinding_nonce": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "trials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "case_id", "stimuli"],
        "properties": {
          "id": { "type": "string" },
          "case_id": { "type": "string" },
          "reference_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "reference_contract": { "$ref": "#/$defs/reference_contract" },
          "x_source": { "type": "string" },
          "stimuli": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["id", "role", "sha256", "source_sha256", "gain_db", "integrated_lufs_before", "integrated_lufs_after", "duration_ms"],
              "properties": {
                "id": { "type": "string" },
                "role": { "enum": ["candidate", "incumbent", "hidden_reference", "anchor"] },
                "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "gain_db": { "type": "number" },
                "integrated_lufs_before": { "type": "number" },
                "integrated_lufs_after": { "type": "number" },
                "duration_ms": { "type": "integer", "minimum": 1 }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "reference_contract": {
      "type": "object",
      "required": ["id", "corpus_id", "status", "declared_path", "reference_sha256", "contract_sha256", "registry_sha256", "registry_schema_sha256"],
      "properties": {
        "id": { "type": "string" },
        "corpus_id": { "type": "string" },
        "status": { "const": "verified" },
        "declared_path": { "type": "string" },
        "reference_sha256": { "$ref": "#/$defs/sha256" },
        "contract_sha256": { "$ref": "#/$defs/sha256" },
        "registry_sha256": { "$ref": "#/$defs/sha256" },
        "registry_schema_sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    }
  }
}
