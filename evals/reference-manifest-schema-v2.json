{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://instruments.js/evals/reference-manifest-schema-v2.json",
  "title": "instruments.js reference contract registry v2",
  "type": "object",
  "required": ["schema_version", "corpora", "contracts"],
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "description": { "type": "string" },
    "corpora": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/corpus" }
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/contract" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "corpus": {
      "type": "object",
      "required": ["id", "status", "name", "license", "provenance_owner", "notes"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "status": { "enum": ["verified", "unverified"] },
        "name": { "type": "string", "minLength": 1 },
        "license": { "type": ["string", "null"] },
        "provenance_owner": { "type": "string", "minLength": 1 },
        "notes": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "contract": {
      "type": "object",
      "required": ["id", "corpus_id", "status", "reference_path", "canonical_sha256", "sample_rate", "level_normalized", "invalid_axes", "notes"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "corpus_id": { "$ref": "#/$defs/id" },
        "status": { "enum": ["verified", "unverified"] },
        "reference_path": { "type": "string", "pattern": "^[^/].+\\.wav$" },
        "canonical_sha256": { "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
        "sample_rate": { "type": ["integer", "null"], "minimum": 8000 },
        "level_normalized": { "type": ["boolean", "null"] },
        "mask_after_s": { "type": "number", "exclusiveMinimum": 0 },
        "invalid_axes": {
          "type": "object",
          "propertyNames": { "enum": ["mr_stft", "attack", "decay", "partials", "lufs", "tail", "release", "velocity_loudness"] },
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "notes": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
