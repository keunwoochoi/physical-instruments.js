{
  "name": "instruments.js",
  "version": "0.0.0",
  "description": "Beautiful physical-modeled instruments for the browser. No samples, tiny bundle, one noteOn() call.",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./worklet": "./worklet/instruments-processor.js",
    "./wasm": "./wasm/instruments_dsp.wasm"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "worklet",
    "wasm",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "keywords": [
    "web-audio",
    "audioworklet",
    "physical-modeling",
    "synthesis",
    "instruments",
    "midi",
    "music",
    "wasm"
  ]
}
